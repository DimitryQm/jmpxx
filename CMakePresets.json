{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "CMAKE_CXX_STANDARD": "20" }
    },
    {
      "name": "dev",
      "displayName": "GCC, C++20, tests on",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "dev-clang",
      "displayName": "Clang, C++20, tests on",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "Clang, Address + UndefinedBehavior sanitizers",
      "inherits": "dev-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -fno-sanitize-recover=all"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev", "configurePreset": "dev" },
    { "name": "dev-clang", "configurePreset": "dev-clang" },
    { "name": "asan-ubsan", "configurePreset": "asan-ubsan" }
  ],
  "testPresets": [
    { "name": "dev", "configurePreset": "dev", "output": { "outputOnFailure": true } },
    { "name": "dev-clang", "configurePreset": "dev-clang", "output": { "outputOnFailure": true } },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "output": { "outputOnFailure": true },
      "description": "Sanitizers slow execution unevenly, so a latency-ratio gate measures the sanitizer not the code and can flake; the timing gates are excluded here and run in the ordinary jobs, while the arm's memory and undefined-behavior coverage stays through the execution and fuzz tiers.",
      "filter": { "exclude": { "name": "benchmark" } }
    }
  ]
}
